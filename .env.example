# URL pública del proyecto (documentada, sin riesgo de exposición)
VITE_SUPABASE_URL=https://oxbsbvbrljzvfqpdozgl.supabase.co

# Anon/publishable key — configurar localmente en .env.local o en entorno de despliegue
# NO es service_role. NO es database password. NO es connection string.
VITE_SUPABASE_ANON_KEY=replace_me_with_supabase_anon_or_publishable_key

# ── Seguridad ──
# NO usar service_role en frontend.
# NO commitear .env.local.
# NO pegar database password aquí.
# NO pegar connection string completa.
# La anon/publishable key se configura localmente o en hosting, nunca en repo.
